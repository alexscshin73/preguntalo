APP_DOMAIN=preguntalo.carroamix.com

OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LOCAL_AI_BASE_URL=http://host.docker.internal:11434
LOCAL_EMBEDDING_MODEL=bge-m3
LOCAL_CHAT_MODEL=qwen2.5:7b
LOCAL_AI_TIMEOUT_SECONDS=30

APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

WEB_PORT=3000
NEXT_PUBLIC_APP_URL=https://preguntalo.carroamix.com
NEXT_PUBLIC_API_BASE_URL=http://api:8000/api/v1
CORS_ORIGINS=https://preguntalo.carroamix.com,http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DB=preguntalo
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://app:change-me@postgres:5432/preguntalo

REDIS_URL=redis://redis:6379/0

STORAGE_BACKEND=s3
LOCAL_STORAGE_ROOT=./data/storage
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=manuals
S3_FORCE_PATH_STYLE=true
